# ============================================
# RABBITMQ
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================
# POSTGRES
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=medisync
POSTGRES_USER=medisync
POSTGRES_PASS=medisync

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development

# ============================================
# SERVICES (ports)
# ============================================
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PATIENT_SERVICE_PORT=3002
DOCTOR_SERVICE_PORT=3003
APPOINTMENTS_SERVICE_PORT=3004

# ============================================
# SERVICE URLs (for inter-service communication)
# ============================================
AUTH_SERVICE_URL=http://auth-service:3001
PATIENT_SERVICE_URL=http://patient-service:3002
DOCTOR_SERVICE_URL=http://doctor-service:3003
APPOINTMENTS_SERVICE_URL=http://appointments-service:3004

# ============================================
# CORS (used by api-gateway)
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# EVENT BROKER TOPOLOGY
# ============================================
EVENTS_EXCHANGE=medi-sync.events
EVENTS_EXCHANGE_TYPE=topic
COMMANDS_EXCHANGE=medi-sync.commands
COMMANDS_EXCHANGE_TYPE=direct

# ============================================
# EMAIL (appointments-service — use Ethereal for local dev)
# ============================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@medisync.local
