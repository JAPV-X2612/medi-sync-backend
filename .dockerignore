# ============================================
# ENVIRONMENT & SECRETS
# ============================================
**/.env
**/.env.*
!**/.env.example

# ============================================
# NODE.JS
# ============================================
**/node_modules/
**/.npm
**/.yarn/

# ============================================
# BUILD OUTPUT
# ============================================
**/dist/
**/build/
**/*.js.map
**/*.d.ts.map
**/*.tsbuildinfo

# ============================================
# TESTING & COVERAGE
# ============================================
**/test/
**/coverage/
**/.nyc_output/
**/test-results/
**/junit.xml

# ============================================
# CACHE
# ============================================
**/.cache/
**/.eslintcache
**/.prettiercache
**/.parcel-cache/

# ============================================
# LOGS
# ============================================
**/*.log
**/*.log.*

# ============================================
# GIT
# ============================================
.git/
.gitignore
.gitattributes

# ============================================
# DOCUMENTATION
# ============================================
README.md
CHANGELOG.md
LICENSE
assets/
contracts/
DELETE/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.code-workspace
.history/

# ============================================
# OS
# ============================================
.DS_Store
._*
Thumbs.db
Desktop.ini

# ============================================
# TEMPORARY FILES
# ============================================
**/*.tmp
**/*.temp
**/*.bak
**/*.swp
**/*.swo
**/tmp/
**/temp/

# ============================================
# DOCKER (no copiar en el contexto)
# ============================================
docker-compose*.yml
.dockerignore
