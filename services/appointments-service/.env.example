# ============================================
# APPLICATION
# ============================================
PORT=3004
NODE_ENV=development

# ============================================
# POSTGRESQL
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medisync
POSTGRES_USER=medisync
POSTGRES_PASS=medisync

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
EVENTS_EXCHANGE=medi-sync.events
COMMANDS_EXCHANGE=medi-sync.commands

# ============================================
# EMAIL (SMTP) — Use Ethereal for local testing:
# Create free credentials at https://ethereal.email
# ============================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@medisync.com
